# ── Keenetic router ──────────────────────────────────────────────────────────
KEENETIC_IP=10.0.1.2# IP роутера (через WG-туннель: 192.168.X.1)
KEENETIC_PORT=80                 # HTTP порт (обычно 80)
KEENETIC_USER=admin              # Логин веб-интерфейса Keenetic
KEENETIC_PASS=xyi12345       # Пароль

# ── Receiver (центральный сервер) ─────────────────────────────────────────────
RECEIVER_URL=http://:8080   # URL сервера-получателя

# ── Шифрование ───────────────────────────────────────────────────────────────
# Любая строка-пароль. Должна совпадать с ENCRYPTION_KEY на сервере.
ENCRYPTION_KEY=замените-на-свой-секретный-пароль-минимум-20-символов

# ── Идентификатор этого роутера ───────────────────────────────────────────────
# Используется как label в Grafana. Уникален для каждого агента.
ROUTER_ID=router-01

# ── Интервал опроса (секунды) ─────────────────────────────────────────────────
POLL_INTERVAL=60
