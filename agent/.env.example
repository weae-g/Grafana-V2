# ── Keenetic router ───────────────────────────────────────────────────────────
KEENETIC_IP=10.0.1.2
KEENETIC_PORT=80
KEENETIC_USER=admin
KEENETIC_PASS=yourpassword

# ── Receiver (центральный сервер) ─────────────────────────────────────────────
RECEIVER_URL=http://localhost:8080

# ── Шифрование ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=замените-на-свой-секретный-пароль-минимум-20-символов

# ── Идентификатор этого роутера ───────────────────────────────────────────────
ROUTER_ID=router-01

# ── Интервал опроса (секунды) ─────────────────────────────────────────────────
POLL_INTERVAL=60

# ── Интерфейсы Keenetic (проверить через /rci/show/interface) ─────────────────
# WireGuard-туннель мониторинга: Wireguard0, Wireguard1, ...
WG_INTERFACE=Wireguard1
# LTE-интерфейс: UsbLte0, UsbModem0, Lte0, ...
LTE_INTERFACE=UsbLte0

# ── Лимит памяти контейнера ────────────────────────────────────────────────────
# Агент лёгкий — 256m хватает с запасом.
# Увеличь до 512m если POLL_INTERVAL очень маленький (< 30s).
MEM_AGENT=256m
