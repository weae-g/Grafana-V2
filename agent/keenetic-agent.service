[Unit]
Description=Keenetic Monitor Agent
After=network.target wg-quick@wg0.service
Wants=network.target

[Service]
Type=simple
User=keenetic-agent
WorkingDirectory=/opt/keenetic-agent
ExecStart=/opt/keenetic-agent/venv/bin/python agent.py
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=keenetic-agent

[Install]
WantedBy=multi-user.target
