# ── Шифрование (должен совпадать с агентом) ───────────────────────────────────
ENCRYPTION_KEY=замените-на-свой-секретный-пароль-минимум-20-символов

# ── InfluxDB ──────────────────────────────────────────────────────────────────
# INFLUXDB_URL — имя сервиса из docker-compose, менять не нужно
INFLUXDB_URL=http://influxdb:8086
# INFLUXDB_TOKEN — должен совпадать с DOCKER_INFLUXDB_INIT_ADMIN_TOKEN ниже
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_ORG=keenetic
INFLUXDB_BUCKET=keenetic

# ── Receiver HTTP ─────────────────────────────────────────────────────────────
LISTEN_PORT=8080
LISTEN_HOST=0.0.0.0

# ── InfluxDB init (только для первого запуска docker-compose) ─────────────────
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=adminpassword123
DOCKER_INFLUXDB_INIT_ORG=keenetic
DOCKER_INFLUXDB_INIT_BUCKET=keenetic
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=my-super-secret-token   # тот же что INFLUXDB_TOKEN
# Retention: 0 = бесконечно. Для ограничения по времени — в часах.
# 720h = 30 дней (~16GB на 50 роутеров)   1080h = 45 дней (~24GB)
DOCKER_INFLUXDB_INIT_RETENTION=720h

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=grafana-admin-pass
GF_SERVER_ROOT_URL=http://localhost:3000

# ── Лимиты памяти контейнеров ─────────────────────────────────────────────────
# Управляй этими значениями чтобы сервер (20 GB) не перегружался.
# Формат: 256m, 1g, 8g и т.д.
# По умолчанию итого: ~8.9 GB — остальное остаётся ОС и другим процессам.
MEM_INFLUXDB=8g        # главный потребитель — хранит все метрики
MEM_RECEIVER=256m      # лёгкий Flask-сервер
MEM_PING_MONITOR=128m  # фоновый ping-монитор
MEM_GRAFANA=512m       # веб-интерфейс
